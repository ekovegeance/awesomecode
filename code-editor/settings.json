{
    // Workbench Settings
    "workbench.colorCustomizations": {
        "titleBar.border": "default",
        "sideBar.border": "#24292e00",
        "scrollbar.shadow": "#24292e00",
        "window.activeBorder": "#000000",
        "scrollbarSlider.background": "#24292e00",
        "inlineparameters.annotationForeground": "#7b82af",
        "inlineparameters.annotationBackground": "#282A3600",
    },
    "workbench.tree.indent": 12,
    "workbench.editor.showTabs": "single",
    "workbench.statusBar.visible": false,
    "workbench.editor.empty.hint": "hidden",
    "workbench.layoutControl.enabled": false,
    "workbench.activityBar.location": "hidden",
    "workbench.settings.applyToAllProfiles": [],
    "workbench.editorLargeFileConfirmation": 10024,
    "workbench.editor.editorActionsLocation": "hidden",
    "workbench.iconTheme": "vscode-jetbrains-icon-theme-2023-dark",

    // Window Settings
    "window.zoomLevel": 1,
    "window.nativeTabs": false,
    "window.commandCenter": false,
    "window.titleBarStyle": "custom",

    // Breadcrumbs Settings 
    "breadcrumbs.enabled": true,
    "breadcrumbs.filePath": "on",
    "breadcrumbs.symbolPath": "off",

    // Editor Settings
    "editor.fontSize": 12,
    "editor.lineHeight": 28,
    "editor.lineNumbers": "on",
    "editor.minimap.size": "fit",
    "editor.language.brackets": [],
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "none",
    "editor.cursorBlinking": "smooth",
    "editor.guides.indentation": false,
    "editor.inlineSuggest.enabled": true,
    "editor.scrollbar.vertical": "hidden",
    "editor.suggest.showStatusBar": false,
    "editor.minimap.showSlider": "always",
    "editor.autoClosingBrackets": "always",
    "editor.renderControlCharacters": false,
    "editor.minimap.renderCharacters": false,
    "editor.scrollbar.verticalScrollbarSize": 1,
    "editor.semanticTokenColorCustomizations": {},
    "editor.codeActionWidget.includeNearbyQuickFixes": true,
    "editor.fontFamily": "Menlo, Monaco, 'Courier New', monospace",
    // extension settings
    "git.autofetch": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    "cursor.cpp.disabledLanguages": [
        "plaintext",
        "markdown",
        "scminput"
    ],
    "typescript.updateImportsOnFileMove.enabled": "always",
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features",
    },
    "[typescript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "javascript.updateImportsOnFileMove.enabled": "always",
    "tailwindCSS.emmetCompletions": true,
    "bladeFormatter.format.sortTailwindcssClasses": true,
    "[blade]": {
        "editor.defaultFormatter": "shufo.vscode-blade-formatter"
    },
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "[javascript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "files.autoSave": "onFocusChange",
}
