{"name":"vscode-setting","settings":"{\"settings\":\"{\\n  \\\"editor.scrollbar.vertical\\\": \\\"hidden\\\",\\n  \\\"editor.scrollbar.verticalScrollbarSize\\\": 1,\\n  \\\"editor.inlineSuggest.enabled\\\": true,\\n  \\\"github.copilot.enable\\\": {\\n    \\\"*\\\": true,\\n    \\\"plaintext\\\": false,\\n    \\\"markdown\\\": false,\\n    \\\"scminput\\\": false\\n  },\\n  \\\"workbench.iconTheme\\\": \\\"material-icon-theme\\\",\\n  \\\"tailwindCSS.emmetCompletions\\\": true,\\n  \\\"bladeFormatter.format.sortTailwindcssClasses\\\": true,\\n  \\\"[blade]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"shufo.vscode-blade-formatter\\\"\\n  },\\n  \\\"[html]\\\": {\\n    \\\"editor.defaultFormatter\\\": \\\"vscode.html-language-features\\\"\\n  },\\n  \\\"redhat.telemetry.enabled\\\": true,\\n  \\\"breadcrumbs.enabled\\\": false,\\n  \\\"editor.guides.indentation\\\": false,\\n  \\\"editor.minimap.renderCharacters\\\": false,\\n  \\\"editor.minimap.size\\\": \\\"fit\\\",\\n  \\\"editor.minimap.showSlider\\\": \\\"always\\\",\\n  \\\"editor.cursorBlinking\\\": \\\"smooth\\\",\\n  \\\"editor.renderWhitespace\\\": \\\"none\\\",\\n  \\\"editor.renderControlCharacters\\\": false,\\n  \\\"editor.codeActionWidget.includeNearbyQuickFixes\\\": true,\\n  \\\"window.zoomLevel\\\": 1,\\n  \\\"workbench.activityBar.location\\\": \\\"hidden\\\",\\n  \\\"[dart]\\\": {\\n    \\\"editor.formatOnSave\\\": true,\\n    \\\"editor.formatOnType\\\": true,\\n    \\\"editor.rulers\\\": [\\n      80\\n    ],\\n    \\\"editor.selectionHighlight\\\": false,\\n    \\\"editor.suggestSelection\\\": \\\"first\\\",\\n    \\\"editor.tabCompletion\\\": \\\"onlySnippets\\\",\\n    \\\"editor.wordBasedSuggestions\\\": \\\"off\\\"\\n  },\\n  \\\"git.autofetch\\\": true,\\n  \\\"workbench.statusBar.visible\\\": false,\\n  \\\"workbench.editor.editorActionsLocation\\\": \\\"hidden\\\",\\n  \\\"window.commandCenter\\\": false,\\n  \\\"workbench.layoutControl.enabled\\\": false,\\n  \\\"workbench.editor.showTabs\\\": \\\"none\\\",\\n  \\\"editor.minimap.enabled\\\": false,\\n  \\\"editor.semanticTokenColorCustomizations\\\": {\\n\\n  }\\n}\"}","snippets":"{\"snippets\":{\"responseSwal.code-snippets\":\"{\\n\\t// Place your global snippets here. Each snippet is defined under a snippet name and has a scope, prefix, body and \\n\\t// description. Add comma separated ids of the languages where the snippet is applicable in the scope field. If scope \\n\\t// is left empty or omitted, the snippet gets applied to all languages. The prefix is what is \\n\\t// used to trigger the snippet and the body will be expanded and inserted. Possible variables are: \\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. \\n\\t// Placeholders with the same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"scope\\\": \\\"javascript,typescript\\\",\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n\\t\\\"Swal Response Data Kosong\\\": {\\n\\t\\t\\\"scope\\\": \\\"javascript,typescript\\\",\\n\\t\\t\\\"prefix\\\": \\\"dataKosong\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"Swal.fire({\\\",\\n\\t\\t\\t\\t\\\"\\\\ttitle: 'Info!',\\\",\\n\\t\\t\\t\\t\\\"\\\\ttext: 'Data Kosong!',\\\",\\n\\t\\t\\t\\t\\\"\\\\ticon: 'info',\\\",\\n\\t\\t\\t\\\"});\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Menampilkan swal data kosong\\\"\\n\\t},\\n\\t\\\"Swal Konfirmasi\\\": {\\n\\t\\t\\\"scope\\\": \\\"javascript,typescript\\\",\\n\\t\\t\\\"prefix\\\": \\\"swalKonfirmasi\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"Swal.fire({\\\",\\n\\t\\t\\t\\t\\\"\\\\ttitle: 'Yakin ingin?'\\\",\\n\\t\\t\\t\\t\\\"\\\\ttext: ''\\\",\\n\\t\\t\\t\\t\\\"\\\\ttype: 'warning'\\\",\\n\\t\\t\\t\\t\\\"\\\\tshowCancelButton: !0\\\",\\n\\t\\t\\t\\t\\\"\\\\tconfirmButtonColor: '#3085d6'\\\",\\n\\t\\t\\t\\t\\\"\\\\tcancelButtonColor: '#d33'\\\",\\n\\t\\t\\t\\t\\\"\\\\tconfirmButtonText: 'Ya!'\\\",\\n\\t\\t\\t\\t\\\"\\\\tcancelButtonText: 'Batal'\\\",\\n\\t\\t\\t\\\"}).then((result) => {\\\",\\n\\t\\t\\t\\t\\\"\\\\tif (result.value) {\\\",\\n\\t\\t\\t\\t\\t\\\"\\\\t\\\\taxios\\\",\\n\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t.post('/perpustakaan/validasi-bebas-pustaka', {id})\\\",\\n\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t.then((response) => {\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\tif (response.data[0].responCode == 1) {\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\t\\\\tSwal.fire({\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\t\\\\t\\\\ttitle: 'Sukses!',\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\t\\\\t\\\\ttext: response.data[0].respon,\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\t\\\\t\\\\ticon: 'success',\\\",                  \\n\\t\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\t\\\\t});\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\t\\\\t$('#modal').hide();\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\t} else {\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\t\\\\tSwal.fire({\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\t\\\\t\\\\ttitle: 'Gagal!',\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\t\\\\t\\\\ttext: response.data[0].respon,\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\t\\\\t\\\\ticon: 'error',\\\",                   \\n\\t\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\t\\\\t});\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\t}\\\",\\n\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t})\\\",\\n\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t.catch((error) => {\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t\\\\tconsole.log(error);\\\",\\n\\t\\t\\t\\t\\t\\t\\\"\\\\t\\\\t\\\\t});\\\",\\n\\t\\t\\t\\t\\\"\\\\t}\\\",\\n\\t\\t\\t\\\"});\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Menampilkan swal konfirmasi\\\"\\n\\t},\\n}\",\"tailwindcss.json\":\"{\\n\\t// Place your snippets for tailwindcss here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n}\"}}","extensions":"[{\"identifier\":{\"id\":\"aaron-bond.better-comments\",\"uuid\":\"7a0110bb-231a-4598-aa1b-0769ea46d28b\"},\"displayName\":\"Better Comments\"},{\"identifier\":{\"id\":\"absszero.vscode-laravel-goto\",\"uuid\":\"c4108071-4eec-4fd6-940e-fb2d99b73546\"},\"displayName\":\"Laravel Goto\"},{\"identifier\":{\"id\":\"amiralizadeh9480.laravel-extra-intellisense\",\"uuid\":\"b52072d1-e507-4261-8935-f4d91a055d7d\"},\"displayName\":\"Laravel Extra Intellisense\"},{\"identifier\":{\"id\":\"anbuselvanrocky.bootstrap5-vscode\",\"uuid\":\"905e2fea-1455-4a73-9319-57b046ce5543\"},\"displayName\":\"Bootstrap 5 Quick Snippets\"},{\"identifier\":{\"id\":\"andrewmcodes.tailwindcss-extension-pack\",\"uuid\":\"0213bf89-6698-493d-bcf7-8609b1fb2e6b\"},\"displayName\":\"Tailwind CSS Extension Pack\",\"disabled\":true},{\"identifier\":{\"id\":\"austenc.laravel-blade-spacer\",\"uuid\":\"853930e5-1159-4957-8a02-1b98ceb3046b\"},\"displayName\":\"Laravel Blade Spacer\"},{\"identifier\":{\"id\":\"austenc.tailwind-docs\",\"uuid\":\"d7890502-5057-436e-904c-8d6639f316d7\"},\"displayName\":\"Tailwind Docs\",\"disabled\":true},{\"identifier\":{\"id\":\"bmewburn.vscode-intelephense-client\",\"uuid\":\"ffda6552-0ad5-431b-a4fa-0905a7e4f3f0\"},\"displayName\":\"PHP Intelephense\"},{\"identif